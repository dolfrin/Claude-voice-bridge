# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Model providers
OPENAI_API_KEY=
# Optional: set only if you want Claude pay-per-token API billing.
# Leave unset to use your local Claude Code subscription login.
# ANTHROPIC_API_KEY=

# Text-to-speech
TTS_BACKEND=openai
TTS_VOICE=alloy
PIPER_VOICE_PATH=/opt/piper/lt_LT-voice.onnx

# Speech-to-text
WHISPER_MODEL=large-v3

# Autonomy / approvals
AUTONOMY_MODE=safe
APPROVAL_TIMEOUT=300

# Persistence
DB_PATH=/var/lib/voice-bridge/state.db

# Project discovery
AUTO_DISCOVER_PROJECTS=false
AUTO_DISCOVER_LIMIT=12
