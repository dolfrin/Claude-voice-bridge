projects:
  - name: app
    display_name: App
    cwd: /home/home/Projects/app
    enabled: true
    autonomy: safe
    voice: alloy
    # Optional model override (omit for the account default). /info shows the
    # configured model alongside the real model that actually answered.
    # model: claude-opus-4-8
    # Optional reasoning effort: low | medium | high | xhigh | max (omit for
    # the SDK default). Change live with /effort <level> [project].
    # effort: high
    system_prompt_extra: ""
    # Opt-in live tool-activity streaming (default false). When true, the
    # session streams compact, text-only tool-activity while it works, so a
    # glance at the phone shows progress. Toggle live with /verbose.
    verbose: false

  - name: api
    display_name: API
    cwd: /home/home/Projects/api
    enabled: false
    autonomy: safe
    voice: echo
    system_prompt_extra: ""
